{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AN Dev Studio",
  "version": "1.0.0",
  "identifier": "com.angroups.andevstudio",
  "build": {
    "frontendDist": "launcher"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "launcher",
        "title": "AN Dev Studio — Setup",
        "url": "index.html",
        "width": 720,
        "height": 640,
        "minWidth": 600,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "resources": ["launcher/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}

{
  "name": "an-dev-studio",
  "version": "1.0.0",
  "private": true,
  "description": "AN GROUPS AI Engineering Platform",
  "packageManager": "npm@11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev":        "npm run dev --workspace=@an-groups/studio",
    "build":      "npm run build --workspace=@an-groups/studio",
    "lint":       "npm run lint --workspace=@an-groups/studio",
    "type-check": "tsc --noEmit --project tsconfig.json && npm run type-check --workspaces --if-present",
    "test":       "vitest run --config vitest.config.mjs && npm run test --workspace=@an-groups/studio",
    "test:watch": "vitest --config vitest.config.mjs",
    "test:ui":    "vitest --ui --config vitest.config.mjs",
    "coverage":   "vitest run --coverage --config vitest.config.mjs",
    "clean":      "npm run clean --workspace=@an-groups/studio"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm":  ">=11.0.0"
  },
  "devDependencies": {
    "@types/node":       "^22",
    "@vitest/coverage-v8": "^2",
    "tsx":               "^4",
    "typescript":        "^5",
    "vitest":            "^2"
  }
}

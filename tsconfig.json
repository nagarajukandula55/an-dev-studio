{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "noEmit": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": ["packages/**/*.ts"],
    "exclude": [
        "node_modules",
        "dist",
        "build",
        ".next",
        "**/__tests__/**",
        "apps",
        "legacy"
    ]
}
